# Personal data (user fills these)
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# User config and customization (never auto-updated)
# NOTE: portals.yml was removed from this list so the Render web service can
# run scan.mjs at runtime. portals.yml contains no secrets — only company
# names, public careers URLs, and title filters.
config/profile.yml
modes/_profile.md
.update-dismissed
.update-lock

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# Secrets — never commit
.env
.env.*
!.env.example

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard
package-lock.json

__pycache__/
*.pyc
